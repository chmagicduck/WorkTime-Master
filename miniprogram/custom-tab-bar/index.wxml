<view class="tab-bar">
  <view
    wx:for="{{tabs}}"
    wx:key="page"
    class="tab-item {{selected === index ? 'tab-item--active' : ''}}"
    data-index="{{index}}"
    data-page="{{item.page}}"
    bindtap="onTabTap"
  >
    <text class="tab-icon">{{item.icon}}</text>
    <text class="tab-label">{{item.label}}</text>
  </view>
</view>
