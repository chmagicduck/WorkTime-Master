/* pages/onboarding/index.wxss */

/* ══════════════════════════════════════════════════════════
   WELCOME PAGE
   ══════════════════════════════════════════════════════════ */

.welcome-page {
  background: #0f172a;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 0 32px 48px;
}

/* top content */
.welcome-top {
  /* padding-top injected via JS */
}

.shield-wrap {
  width: 64px;
  height: 64px;
  background: #2563eb;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28px;
  box-shadow: 0 8px 32px rgba(37, 99, 235, 0.5);
}

.shield-emoji {
  font-size: 30px;
}

.welcome-title {
  display: block;
  font-size: 34px;
  font-weight: 900;
  color: #ffffff;
  line-height: 1.2;
  letter-spacing: -0.03em;
  margin-bottom: 16px;
}

.welcome-subtitle {
  display: block;
  font-size: 16px;
  color: #94a3b8;
  line-height: 1.6;
}

/* bottom button */
.welcome-bottom {
  /* stays at bottom via space-between */
}

.btn-start {
  background: #2563eb;
  border-radius: 20px;
  padding: 18px 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 8px;
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.4);
}

.btn-start:active {
  transform: scale(0.97);
}

.btn-start-text {
  font-size: 18px;
  font-weight: 900;
  color: #ffffff;
}

.btn-start-arrow {
  font-size: 24px;
  color: rgba(255, 255, 255, 0.75);
  line-height: 1;
}


/* ══════════════════════════════════════════════════════════
   SETUP PAGE
   ══════════════════════════════════════════════════════════ */

.setup-page {
  background: #ffffff;
  display: flex;
  flex-direction: column;
}

/* header */
.setup-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 0 24px 20px;
  gap: 2px;
  flex-shrink: 0;
  /* padding-top injected via JS */
  height: 56px;
  box-sizing: content-box;
}

.back-btn {
  padding: 8px 10px 8px 2px;
  margin-left: -4px;
}

.back-chevron {
  font-size: 30px;
  font-weight: 300;
  color: #94a3b8;
  line-height: 1;
  display: block;
}

.setup-title {
  font-size: 20px;
  font-weight: 900;
  color: #0f172a;
}

/* scrollable form */
.form-scroll {
  flex: 1;
  /* height injected via JS */
}

.form-inner {
  padding: 8px 24px 56px;
}

/* form group */
.form-group {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 10px;
  font-weight: 900;
  color: #94a3b8;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 8px;
}

/* text input */
.form-input {
  display: block;
  width: 100%;
  background: #f8fafc;
  border-radius: 16px;
  padding: 16px;
  font-size: 18px;
  font-weight: 700;
  color: #0f172a;
  box-sizing: border-box;
}

.input-placeholder {
  color: #cbd5e1;
  font-weight: 400;
}

/* picker field */
.picker-field {
  background: #f8fafc;
  border-radius: 16px;
  padding: 16px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.picker-val {
  font-size: 16px;
  font-weight: 700;
  color: #0f172a;
}

.picker-val--sm {
  font-size: 13px;
}

.picker-chevron {
  font-size: 22px;
  color: #94a3b8;
  margin-top: -2px;
}

/* two-column row */
.form-row-2 {
  display: flex;
  flex-direction: row;
  gap: 12px;
  margin-bottom: 16px;
}

.form-group--half {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

/* lunch break toggle card */
.toggle-card {
  background: #eff6ff;
  border-radius: 16px;
  padding: 16px;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.toggle-info {
  flex: 1;
  margin-right: 12px;
}

.toggle-title {
  display: block;
  font-size: 14px;
  font-weight: 900;
  color: #1e3a8a;
}

.toggle-desc {
  display: block;
  font-size: 10px;
  color: #3b82f6;
  margin-top: 4px;
}

/* alternate week section */
.alternate-section {
  background: #f8fafc;
  border-radius: 16px;
  padding: 16px 16px 0;
  margin-bottom: 16px;
}

.alternate-hint {
  display: block;
  font-size: 11px;
  font-weight: 700;
  color: #64748b;
  margin-bottom: 12px;
}

/* save button */
.btn-save {
  background: #0f172a;
  border-radius: 20px;
  padding: 18px 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  margin-top: 16px;
  box-shadow: 0 8px 24px rgba(15, 23, 42, 0.2);
}

.btn-save:active {
  transform: scale(0.97);
}

.btn-save-text {
  font-size: 17px;
  font-weight: 900;
  color: #ffffff;
}
