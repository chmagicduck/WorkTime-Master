<!-- pages/profile/index.wxml -->
<view class="profile-page"
      style="height: {{pageHeight}}px">

  <!-- ① Header -->
  <view class="profile-header"
        style="padding-top: {{statusBarHeight}}px">
    <text class="header-title">工位存档</text>
    <text class="header-icon">⚙</text>
  </view>

  <!-- ② Scrollable content -->
  <scroll-view class="profile-scroll"
               scroll-y
               style="height: {{scrollHeight}}px">
    <view class="profile-inner">

      <!-- 个人名片 -->
      <view class="profile-card">
        <view class="avatar">
          <text class="avatar-text">牛</text>
        </view>
        <view class="profile-info">
          <text class="profile-name">{{levelTitle}}</text>
          <view class="profile-meta">
            <text class="level-badge">等级 {{level}}</text>
            <text class="total-earnings-text">搬砖总额：¥{{totalEarnings}}</text>
          </view>
          <text class="config-summary">{{configSummary}}</text>
        </view>
      </view>

      <!-- 设置项列表 -->
      <view class="settings-list">

        <!-- 收益设置 -->
        <view class="settings-item" bindtap="goToSettings">
          <view class="item-icon-wrap item-icon-wrap--blue">
            <text class="item-icon-emoji">📈</text>
          </view>
          <text class="item-label">收益设置</text>
          <text class="item-tail">›</text>
        </view>

        <!-- 清除全局数据 -->
        <view class="settings-item settings-item--danger" bindtap="showResetDialog">
          <view class="item-icon-wrap item-icon-wrap--red">
            <text class="item-icon-emoji">🗑</text>
          </view>
          <text class="item-label item-label--danger">清除全局数据</text>
          <text class="item-tail item-tail--warning">⚠</text>
        </view>

      </view>

    </view>
  </scroll-view>

  <!-- ③ Home indicator -->
  <view class="home-indicator"></view>

  <!-- ④ 清除确认弹窗 -->
  <view wx:if="{{showResetConfirm}}" class="modal-overlay">
    <view class="modal-sheet">
      <view class="modal-icon-wrap">
        <text class="modal-icon-text">⚠</text>
      </view>
      <text class="modal-title">清除所有痕迹？</text>
      <text class="modal-desc">此操作将删除您所有的薪资配置、摸鱼历史及统计数据。该操作不可撤销。</text>
      <view class="modal-btns">
        <view class="btn-danger" bindtap="confirmReset">
          <text class="btn-danger-text">确定删除</text>
        </view>
        <view class="btn-cancel" bindtap="cancelReset">
          <text class="btn-cancel-text">我再想想</text>
        </view>
      </view>
    </view>
  </view>

</view>
