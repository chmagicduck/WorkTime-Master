/* pages/profile/index.wxss */

/* ─── Page wrapper ──────────────────────────────────────── */
.profile-page {
  background: #f8fafc;
  display: flex;
  flex-direction: column;
}

/* ─── Header ────────────────────────────────────────────── */
.profile-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-left: 24px;
  padding-right: 24px;
  padding-bottom: 20px;
  flex-shrink: 0;
  height: 56px;
  box-sizing: content-box;
}

.header-title {
  font-size: 20px;
  font-weight: 900;
  color: #0f172a;
}

.header-icon {
  font-size: 20px;
  color: #94a3b8;
}

/* ─── Scroll area ───────────────────────────────────────── */
.profile-scroll {
  flex: 1;
}

.profile-inner {
  padding: 0 20px 32px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* ─── Personal card ─────────────────────────────────────── */
.profile-card {
  background: #ffffff;
  border-radius: 32px;
  border: 1px solid #f1f5f9;
  padding: 24px;
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
}

.avatar {
  width: 64px;
  height: 64px;
  border-radius: 9999px;
  background: linear-gradient(135deg, #3b82f6 0%, #6366f1 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 24px;
  font-weight: 900;
  color: #ffffff;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  font-size: 17px;
  font-weight: 900;
  color: #1e293b;
}

.profile-meta {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 8px;
  margin-top: 6px;
}

.level-badge {
  font-size: 10px;
  background: #d1fae5;
  color: #059669;
  padding: 2px 8px;
  border-radius: 9999px;
  font-weight: 700;
}

.total-earnings-text {
  font-size: 10px;
  color: #94a3b8;
}

.config-summary {
  display: block;
  font-size: 11px;
  color: #cbd5e1;
  margin-top: 6px;
}

/* ─── Settings list ─────────────────────────────────────── */
.settings-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.settings-item {
  background: #ffffff;
  border-radius: 20px;
  border: 1px solid #f1f5f9;
  padding: 20px;
  display: flex;
  flex-direction: row;
  align-items: center;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.03);
}

.settings-item:active {
  background: #f8fafc;
}

.settings-item--danger:active {
  background: #fef2f2;
}

.item-icon-wrap {
  width: 40px;
  height: 40px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
}

.item-icon-wrap--blue {
  background: #eff6ff;
}

.item-icon-wrap--red {
  background: #fef2f2;
}

.item-icon-emoji {
  font-size: 18px;
}

.item-label {
  flex: 1;
  font-size: 15px;
  font-weight: 700;
  color: #475569;
}

.item-label--danger {
  color: #ef4444;
}

.item-tail {
  font-size: 22px;
  color: #cbd5e1;
}

.item-tail--warning {
  font-size: 16px;
  color: #fca5a5;
}

/* ─── Home indicator ────────────────────────────────────── */
.home-indicator {
  width: 128px;
  height: 5px;
  background: #e2e8f0;
  border-radius: 9999px;
  margin: 10px auto 12px;
  flex-shrink: 0;
}

/* ─── Reset modal overlay ───────────────────────────────── */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.6);
  z-index: 100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 24px;
  box-sizing: border-box;
}

.modal-sheet {
  background: #ffffff;
  border-radius: 32px;
  padding: 32px;
}

.modal-icon-wrap {
  width: 64px;
  height: 64px;
  background: #fef2f2;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24px;
}

.modal-icon-text {
  font-size: 28px;
}

.modal-title {
  display: block;
  font-size: 22px;
  font-weight: 900;
  color: #0f172a;
  margin-bottom: 8px;
}

.modal-desc {
  display: block;
  font-size: 14px;
  color: #64748b;
  line-height: 1.7;
  margin-bottom: 32px;
}

.modal-btns {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.btn-danger {
  background: #ef4444;
  border-radius: 16px;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-danger:active {
  background: #dc2626;
}

.btn-danger-text {
  font-size: 17px;
  font-weight: 900;
  color: #ffffff;
}

.btn-cancel {
  background: #f1f5f9;
  border-radius: 16px;
  padding: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-cancel:active {
  background: #e2e8f0;
}

.btn-cancel-text {
  font-size: 17px;
  font-weight: 900;
  color: #64748b;
}
